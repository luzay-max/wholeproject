# 开发环境配置
VITE_APP_ENV=development

# 后端 API 基础 URL
VITE_APP_BASE_API=http://localhost:8080/api

# OSS 配置
VITE_OSS_ACCESS_KEY=your-access-key
VITE_OSS_SECRET_KEY=your-secret-key
VITE_OSS_BUCKET=your-bucket-name
VITE_OSS_ENDPOINT=your-oss-endpoint
VITE_OSS_REGION=your-oss-region

# 应用信息
VITE_APP_NAME=校园失物招领平台
VITE_APP_VERSION=1.0.0

# 开发服务器配置
VITE_PORT=5174
VITE_OPEN=true
VITE_HMR=true